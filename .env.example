# Local Docker deployment configuration.
#
# Copy this file to .env, then fill in YOUR OWN model API settings:
#   cp .env.example .env
#   docker compose up --build
#
# Never commit .env. API usage and billing belong to your own model provider.

# ── Postgres ─────────────────────────────────────────────
# Local-only default. Change this before exposing the app beyond your machine.
POSTGRES_DB=gameops
POSTGRES_USER=gameops
POSTGRES_PASSWORD=gameops-local-password

# ── Local app mode ───────────────────────────────────────
# Root docker-compose.yml is a single-user local development stack.
# Do not expose this no-auth mode to an untrusted network.
OMNIGENT_AUTH_ENABLED=0
OMNIGENT_AUTH_PROVIDER=
# Optional enterprise API key for all /v1/gameops/* endpoints.
# Set this before exposing GameOps beyond a trusted local machine.
GAMEOPS_API_KEY=

# GameOps execution state. The Docker server service mounts /data on a
# persistent volume, so task state, approvals, blocked runs, and execution
# evidence survive container restarts. Leave blank for in-memory local Python
# runs.
GAMEOPS_EXECUTION_HISTORY_PATH=/data/gameops-execution-audit.jsonl
GAMEOPS_EXECUTION_TASKS_PATH=/data/gameops-execution-tasks.json
# Optional production-style SQLite store. When set, this takes precedence over
# the JSONL/JSON paths above and stores history/tasks in one DB file.
GAMEOPS_EXECUTION_DB_PATH=/data/gameops-execution.db
# Optional JSON policy override for roles, risk, retry, approval and evidence rules.
GAMEOPS_EXECUTION_POLICY_PATH=/app/docs/gameops-execution-policy.example.json
# Enterprise GameOps knowledge source. Put your own Markdown policies,
# activity rules, support handbooks, and incident runbooks in this directory.
# The app does not load repository starter documents at runtime.
GAMEOPS_KNOWLEDGE_DIR=/data/gameops-knowledge
# Keep true/blank for safe dry-run receipts. Set to false only after binding
# internal business-system APIs behind the tool adapter contract.
GAMEOPS_TOOL_DRY_RUN=true
# Enterprise rollout check:
#   GET /v1/gameops/enterprise/readiness
# It reports whether persistence, policy file, auth, model credentials and
# business-tool adapters are ready for an enterprise pilot.

# ── BYO model API ────────────────────────────────────────
# OpenAI-compatible covers OpenAI, DeepSeek, Qwen/DashScope compatible mode,
# Moonshot, SiliconFlow, OpenRouter, LM Studio, vLLM and Ollama gateways.
LLM_PROVIDER=openai-compatible
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here

# Optional standard provider variables. Leave blank to let the host container
# derive OpenAI-compatible runner env from the LLM_* values above.
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=
HARNESS_OPENAI_AGENTS_MODEL=

# Anthropic / Claude API example:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-6
#   LLM_BASE_URL=https://api.anthropic.com/v1
#   LLM_API_KEY=your_anthropic_key_here
# You may also use the native Anthropic env names below.
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
HARNESS_CLAUDE_SDK_MODEL=

# Provider examples:
# DeepSeek:     LLM_BASE_URL=https://api.deepseek.com/v1 LLM_MODEL=deepseek-chat
# 通义千问:     LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 LLM_MODEL=qwen-plus
# Moonshot:     LLM_BASE_URL=https://api.moonshot.cn/v1 LLM_MODEL=moonshot-v1-8k
# SiliconFlow:  LLM_BASE_URL=https://api.siliconflow.cn/v1 LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
# Local Ollama: LLM_BASE_URL=http://host.docker.internal:11434/v1 LLM_MODEL=qwen2.5-coder:7b LLM_API_KEY=ollama

# Extra env names to forward from the host container to spawned runner processes.
# The compose command appends the required model override variable automatically.
OMNIGENT_RUNNER_ENV_PASSTHROUGH=

# ── Build-time mirrors ───────────────────────────────────
# Override only if your network blocks the public registries.
PYPI_INDEX_URL=https://pypi.org/simple
NPM_CONFIG_REGISTRY=
